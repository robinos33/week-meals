# Configuration du dev local. Copier ce fichier vers .env (jamais versionné) :
#   cp .env.example .env
# docker-compose lit .env pour provisionner Postgres ; l'API lit les mêmes clés.

# --- PostgreSQL (docker-compose) ---
POSTGRES_USER=weekmeals
POSTGRES_PASSWORD=weekmeals
POSTGRES_DB=weekmeals
POSTGRES_PORT=5432

# --- Connexion API → base ---
# En prod : URL Neon (sslmode=require). En local : le conteneur ci-dessus.
DATABASE_URL=postgres://weekmeals:weekmeals@localhost:5432/weekmeals

# --- Mode d'authentification (cf. ADR-0006) ---
# disabled : l'API cesse d'exiger une session et scope tout au foyer de démo
#            (migration seed_demo_household, UUID 0000…0001). Pour le dev / la
#            preview, sans passkey. NE JAMAIS utiliser en prod.
# locked   : seuls les appareils enrôlés (passkeys) passent. Défaut si absent —
#            on échoue fermé. (L'ancien AUTH_DISABLED=1 reste accepté = disabled.)
AUTH_MODE=disabled

# --- WebAuthn / passkeys (mode locked, cf. ADR-0006) ---
# rp_id     : le domaine (sans schéma ni port) partagé par le front et l'API.
#             En prod, front et API doivent partager le même domaine parent
#             (ex. app.exemple.fr + api.exemple.fr → rp_id = exemple.fr).
#             Déduit de WEBAUTHN_RP_ORIGIN si absent ; `localhost` en dev.
# rp_origin : l'URL complète du front (schéma + domaine + port). Défaut : WEB_ORIGIN.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:5173

# --- Sessions (tower-sessions) ---
# Les sessions sont stockées côté serveur (table `tower_sessions.session`,
# store Postgres) ; le cookie ne porte qu'un identifiant opaque. Réservé pour
# un éventuel usage de signature/chiffrement futur.
#   openssl rand -base64 64
SESSION_SECRET=change-me-genere-une-cle-aleatoire-de-64-octets

# Cookie `Secure` (HTTPS obligatoire) : 1 en prod, vide/0 en dev HTTP local.
SESSION_SECURE=0
# `SameSite` du cookie : lax en dev (même site), none requis si le front et
# l'API sont sur des domaines distincts (prod Pages ↔ Scaleway) — impose Secure=1.
SESSION_SAME_SITE=lax

# --- CORS ---
# Origine du front autorisée à appeler l'API avec cookies (pas de `*`).
# En dev : le serveur Vite. En prod : l'URL Cloudflare Pages.
WEB_ORIGIN=http://localhost:5173

# --- Photos de recettes — stockage S3-compatible (R2 en prod, MinIO en dev) ---
# Upload par URL présignée (cf. ADR-0001) : l'API présigne, le navigateur PUT
# directement le fichier, puis stocke R2_PUBLIC_BASE_URL/clé dans la recette.
# En dev : le service MinIO du docker-compose (valeurs par défaut ci-dessous).
# En prod : Cloudflare R2 — R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com,
# R2_PUBLIC_BASE_URL = domaine public du bucket (r2.dev ou custom), R2_REGION=auto.
# Laisser R2_ENDPOINT vide désactive l'upload (la présignature répond 503).
# MINIO_PORT/MINIO_CONSOLE_PORT : ports hôte du conteneur MinIO (si 9000/9001
# sont pris) — penser à aligner R2_ENDPOINT et R2_PUBLIC_BASE_URL sur MINIO_PORT.
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
R2_ENDPOINT=http://localhost:9000
R2_REGION=us-east-1
R2_BUCKET=week-meals-photos
R2_ACCESS_KEY_ID=weekmeals
R2_SECRET_ACCESS_KEY=weekmeals-secret
R2_PUBLIC_BASE_URL=http://localhost:9000/week-meals-photos
