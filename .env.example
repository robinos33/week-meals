# Configuration du dev local. Copier ce fichier vers .env (jamais versionné) :
#   cp .env.example .env
# docker-compose lit .env pour provisionner Postgres ; l'API lit les mêmes clés.

# --- PostgreSQL (docker-compose) ---
POSTGRES_USER=weekmeals
POSTGRES_PASSWORD=weekmeals
POSTGRES_DB=weekmeals
POSTGRES_PORT=5432

# --- Connexion API → base ---
# En prod : URL Neon (sslmode=require). En local : le conteneur ci-dessus.
DATABASE_URL=postgres://weekmeals:weekmeals@localhost:5432/weekmeals

# --- Sessions (tower-sessions) ---
# Clé de signature des cookies de session. Générer une valeur aléatoire :
#   openssl rand -base64 64
SESSION_SECRET=change-me-genere-une-cle-aleatoire-de-64-octets

# --- Bootstrap du premier compte (cf. ADR-0002) ---
# Code d'invitation consommé UNE seule fois pour créer le compte initial,
# l'inscription publique étant désactivée. Changer avant tout déploiement.
BOOTSTRAP_INVITE_CODE=change-me

# --- Cloudflare R2 — photos de recettes (optionnel en dev) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=week-meals-photos
