# Configuration du front (Vite). Copier vers .env.local puis ajuster.
# Les variables exposées au client DOIVENT être préfixées par VITE_.

# URL de base de l'API Week Meals.
#  - dev local : http://localhost:8080 (le serveur Axum).
#  - prod      : l'URL de l'API (Scaleway Serverless Containers).
# Laisser vide pour des requêtes same-origin (si un proxy sert l'API).
VITE_API_URL=http://localhost:8080
